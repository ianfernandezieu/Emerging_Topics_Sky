# OpenSky Network credentials (optional but recommended for higher rate limits)
# Create account at: https://opensky-network.org/
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# FlightRadarAPI toggle (set to false to disable live enrichment)
FLIGHTRADAR_ENABLED=true

# FlightRadar24 Official API credentials (if you have access)
FR24_CLIENT_ID=
FR24_CLIENT_SECRET=

# Data collection settings
DATA_START_DATE=2025-03-01
DATA_END_DATE=2026-03-27
TARGET_AIRPORT_ICAO=LEMD
TARGET_AIRPORT_IATA=MAD

# Airport coordinates (Madrid-Barajas)
AIRPORT_LAT=40.4936
AIRPORT_LON=-3.5668
